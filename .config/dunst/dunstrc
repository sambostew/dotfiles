# Dunst — modernised 2026-07-18 (was a pre-1.5 config: geometry/[shortcuts]).
# Same design language as waybar/rofi: near-solid black, thin pywal-accent
# frame, rounded corners. Colours live in dunstrc.d/99-wal.conf (symlink to
# the wal-rendered ~/.cache/wal/colors-dunst.conf) so every wal run re-tints.

[global]
    follow = mouse

    width = (300, 460)
    height = (0, 400)
    origin = top-right
    # layer-shell positions below the bar's exclusive zone automatically
    offset = (20, 20)
    gap_size = 8

    padding = 14
    horizontal_padding = 16
    frame_width = 1
    corner_radius = 12
    separator_height = 1
    separator_color = frame

    font = UbuntuMono Nerd Font 12
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    word_wrap = yes
    show_age_threshold = 60
    ellipsize = middle
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    sort = yes
    idle_threshold = 120

    icon_position = left
    max_icon_size = 48
    enable_recursive_icon_lookup = true

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 0
    progress_bar_corner_radius = 4

    sticky_history = yes
    history_length = 20

    browser = /usr/bin/firefox -new-tab
    always_run_script = true
    title = Dunst
    class = Dunst

    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

[urgency_low]
    timeout = 10
    icon = /home/simon/.config/dunst/dragonball.png

[urgency_normal]
    timeout = 10
    icon = /home/simon/.config/dunst/dragonball.png

[urgency_critical]
    timeout = 0
    icon = /home/simon/.config/dunst/dragonball.png

# vim: ft=cfg
