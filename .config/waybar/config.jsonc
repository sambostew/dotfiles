{
    "layer": "top",
    "position": "top",
    "height": 40,
    // no "output" key â†’ one bar per monitor (replaces launch.sh loop)

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock#time"],
    // privacy is invisible unless mic/screenshare is live â€” no idle footprint
    "modules-right": ["privacy", "network", "idle_inhibitor", "custom/notification", "custom/updates", "pulseaudio", "clock#date"],

    "hyprland/workspaces": {
        // ids only in hyprland now (defaultName dropped) â€” icon per role here.
        // 1 mail | 2 firefox | 3 nvim | 4 music | 5 browser | 6 obsidian | 7-9 VMs
        "format": "{icon}",
        "format-icons": {
            "1": "َ°‡®",
            "2": "َ°ˆ¹",
            "3": "َ°†چ",
            "4": "َ°‌ڑ",
            "5": "َ°–ں",
            "6": "َ°ژ‍",
            "7": "َ°چ¹",
            "8": "َ°چ¹",
            "9": "َ°چ¹",
            "default": "َ°‌¦"
        },
        "on-click": "activate"
    },

    "network": {
        "interface": "enp6s0",
        "interval": 1,
        "format": "َ°‡ڑ {bandwidthDownBytes}   َ°•’ {bandwidthUpBytes}",
        "format-disconnected": "َ°²› disconnected"
    },

    "pulseaudio": {
        "format": "َ°•¾ {volume}%",
        "format-muted": "َ°‌ں muted"
    },

    "custom/updates": {
        // relies on systemd update.timer (hourly pacman -Sy) keeping the sync DB fresh.
        // Shared cache script: the three bars exec independently and raced the
        // sync, showing different counts. 300s re-read converges them fast.
        "exec": "~/.config/waybar/updates.sh",
        "return-type": "json",
        "interval": 300,
        "format": "َ°ڈ” {}"
    },

    "clock#time": {
        "interval": 1,
        "format": "َ°¥” {:%H:%M:%S}"
    },

    "clock#date": {
        "interval": 60,
        "format": "َ°ƒ­ {:%Y-%m-%d}"
    },

    // caffeine toggle â€” click to hold off the 5-min hypridle lock
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "َ°…¶",
            "deactivated": "َ°¾ھ"
        }
    },

    "privacy": {
        "icon-spacing": 8,
        "icon-size": 16,
        "modules": [
            { "type": "screenshare" },
            { "type": "audio-in" }
        ]
    },

    "custom/notification": {
        // swaync-client -swb streams JSON on every notification add/close â€”
        // no interval/exec polling needed, waybar just reads the stream.
        "tooltip": true,
        "format": "{icon}",
        // colour comes from style.css (@accent, re-tints with wal) â€” no
        // inline markup here, glyph only. Bell / bell-slash (DND) + a small
        // circle badge superscript when there's something unread
        "format-icons": {
            "notification": "ïƒ³<sup>ï„‘</sup>",
            "none": "ïƒ³",
            "dnd-notification": "ï‡¶<sup>ï„‘</sup>",
            "dnd-none": "ï‡¶",
            "inhibited-notification": "ïƒ³<sup>ï„‘</sup>",
            "inhibited-none": "ïƒ³",
            "dnd-inhibited-notification": "ï‡¶<sup>ï„‘</sup>",
            "dnd-inhibited-none": "ï‡¶"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        // swaync-client -swb connects straight to swaync; if swaync ever
        // restarts or crashes that connection dies and waybar won't relaunch
        // it on its own, freezing the icon on stale state forever. Cap the
        // wait so it self-heals.
        "restart-interval": 5,
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    }
}
